FROM golang:1.26 AS builder
ARG TARGETOS
ARG TARGETARCH

WORKDIR /workspace
COPY go.mod go.sum ./
RUN go mod download

COPY cmd/attestation-service/ cmd/attestation-service/
COPY api/ api/
COPY internal/ internal/

RUN CGO_ENABLED=0 GOOS=${TARGETOS:-linux} GOARCH=${TARGETARCH:-amd64} \
    go build -a -o attestation-service ./cmd/attestation-service/

FROM gcr.io/distroless/static:nonroot
WORKDIR /
COPY --from=builder /workspace/attestation-service .
USER 65532:65532
ENTRYPOINT ["/attestation-service"]
